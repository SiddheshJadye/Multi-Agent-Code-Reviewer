# ---- Required ----
# Your Google Gemini API key (https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=
# ---- Optional (sensible defaults shown) ----
# Gemini model used by both agents
MODEL_NAME=gemini-2.5-flash

# Hard cap on Coder<->Reviewer cycles (stop condition / cost guard)
MAX_ITERATIONS=3

# Sampling temperatures
CODER_TEMPERATURE=0.1
REVIEWER_TEMPERATURE=0.0

# Logging verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ---- Optional: LangSmith tracing ----
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=your-langsmith-key
# LANGSMITH_PROJECT=multi-agent-code-reviewer
